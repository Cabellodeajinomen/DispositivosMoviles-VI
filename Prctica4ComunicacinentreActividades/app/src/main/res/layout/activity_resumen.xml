<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTituloResumen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/titulo_resumen"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvNombreEtiqueta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_nombre" />

    <TextView
        android:id="@+id/tvNombreValor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvEdadEtiqueta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_edad" />

    <TextView
        android:id="@+id/tvEdadValor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvCiudadEtiqueta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_ciudad" />

    <TextView
        android:id="@+id/tvCiudadValor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvCorreoEtiqueta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_correo" />

    <TextView
        android:id="@+id/tvCorreoValor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnConfirmar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:text="@string/btn_confirmar" />

    <Button
        android:id="@+id/btnVolverEditar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_volver_editar" />

</LinearLayout>

